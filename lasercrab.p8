menuitem(1,"quit to menu",function()run_later(function()inmenu=true reload() usecpu=false p={x=10,y=100,vx=0,vy=0,f=1,w=8,h=8,hp=30,lac=50,flipx=false,pwr=0,pwrt=0} p2={x=105,y=100,vx=0,vy=0,f=1,w=8,h=8,hp=30,lac=50,flipx=false,pwr=0,pwrt=0} music(-1)

 end, 15)start_fade() end)

function updtmenu()
	if inmenu then
		ltick=-900
		if (btnp(⬆️)) m.index -= 1
		if (btnp(⬇️)) m.index += 1
		if (btn(🅾️)) items[m.index].func()
		m.index=mid(1,m.index,#items)
	end
end

function drawmenu()
	if inmenu then
		cls()
		draw_big(bg)
		rrectfill(15,9,98,21,5,1)
		rrectfill(15,8,98,21,5,15)
		spr(64,20,11+sin(time()),11,2)
		for i in all(items) do
			if i == items[m.index] then cprint("\^o1ff\14< "..i.txt.." >",i.x,i.y,7)
			else cprint("\14"..i.txt,i.x,i.y,5)
		end
		end
	end
end
-->8
--utils

function cprint(txt,x,y,c)
	cursor()
	clip(0,0,0,0)
	w,h=?txt
	clip()
	?txt,x-w/2,y,c
end

function lerp(from, to, weight)
	local dist = to - from
	if (abs(dist) < 0.2) then
		return to
	end
	return from + (dist * weight)
end

function run_later(func,t)
	local rl = {
		func=func,
		t=t,
		update=function(s)
			s.t-=1
			if(s.t<1)s:func()del(delays,s)
		end,
	}
	add(delays,rl)
end
-->8
--cpu

function cpupdate()
	--x movement
	if(p.x<p2.x-10)p2.vx-=1
	if(p.x>p2.x+10)p2.vx+=1 
	if(p.x<p2.x)p2.flipx=true
	if(p.x>p2.x)p2.flipx=false
	
	--jumping
	if p.y-3 < p2.y and p2.pwr~=2then
		if(tcol(p2.x+12,p2.y+10)and p2.flipx)p2.vy=-3.5
		if(tcol(p2.x-4,p2.y+10)and not p2.flipx)p2.vy=-3.5
	end
	
	--self presevation
	if(p.y>127 or (p.x~=mid(0,p.x,127))or p2.pwr==2)p2.vx = 0
	
	--attacking 
	if p2.y<p.y+3 and p2.y>p.y-3 and p2.pwr~=2and  p2.lac > 1 then
		if p2.flipx then
			p2.vx += 0.2 shoot(p2.x,p2.y+2,-3,0,8) p2.lac-=1.5 
		else
			p2.vx -= 0.2 shoot(p2.x+10,p2.y+2,3,0,8) p2.lac-=1.5 
		end
	end
end

function cpu()
	if(usecpu)usecpu=false
	if(not usecpu)usecpu=true
end
