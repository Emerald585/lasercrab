function draw_big(draw_arr) 
    local fn = {line,rectfill,circfill,ovalfill,line,rect,circ,oval}
    for i,v in ipairs(draw_arr) do
        local shape,col,x1,y1,x2,y2 = unpack(v)
        local a = fn[shape]
        if shape == 3 or shape == 7 then
            a(x1, y1, x2, col)
        elseif shape == 127 then
            fillp()
        elseif shape == 126 then
            fillp(ord(chr(x1)))
        else
            a(x1, y1, x2, y2, col)
        end
    end
end
