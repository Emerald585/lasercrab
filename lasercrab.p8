function effect(x,y,vx,vy,c,s)
	local fx = {
		x=x,
		y=y,
		vx=vx,
		vy=vy,
		c=c,
		s=s,
	}
	add(particle,fx)
end

function fxupdate()
	for fx in all(particle) do
		fx.x += fx.vx
		fx.y += fx.vy
		fx.s -= .1
		if fx.s < 0 then del(particle, fx) end
	end
end


function newitem(x,y,t)
	local i = {
	x=x,
	y=y,
	vy=0,
	t=t}
	add(item,i)
end

function updateitem()
	for i in all(item) do
		if tcol(i.x,i.y+4,0) then i.vy-=i.vy*1.5 else i.vy += 0.1end
		i.y+=i.vy*tspd
		if i.t == 56 then
			if prc(i,p) then sfx(2)p.hp += 10 del(item,i)
			elseif prc(i,p2) then sfx(2)p2.hp += 10 del(item,i) end
		elseif i.t == 57 then
			if prc(i,p) then sfx(2)p.pwr=1 p.pwrt=70 del(item,i)
			elseif prc(i,p2) then sfx(2) p2.pwr=1 p2.pwrt=70 del(item,i) end
		elseif i.t == 58 then
			if prc(i,p) then sfx(2)p2.pwr=2 p2.pwrt=140 del(item,i)
			elseif prc(i,p2) then sfx(2) p.pwr=2 p.pwrt=140 del(item,i) end
		elseif i.t == 59 then
			if prc(i,p) then sfx(2)tspd *= .5 del(item,i)
			elseif prc(i,p2) then sfx(2)tspd *= .5 del(item,i) end
		end
	end
end

function easeoutinquart(t)
	if t<.5 then
		t-=.5
		return .5-8*t*t*t*t
	else
		t-=.5
		return .5+8*t*t*t*t
	end
end


function prc(p,r)
  return p.x >= r.x and
         p.x <= r.x+r.w and
         p.y >= r.y and
         p.y <= r.y+r.h
end

function tcol(x,y,flag)
	return fget(mget(x\8,y\8),flag)
end

function shoot(x,y,vx,vy,c)
	local b = {  
		x=x,
		y=y,
		vx=vx,
		vy=vy,
		c=c
	}
	add(bullet,b)
	sfx(0)
end

function start_fade()
	fadep=0
	dofade=true
end

function bullet_update()
	for b in all(bullet) do
		b.x += b.vx*tspd
		b.y += b.vy*tspd
		if b.x > 130 then del(bullet, b) end
		if b.x < 0 then del(bullet, b) end
--		if (tcol(b.x,b.y,0)) b.vx *= -1
		if (tcol(b.x,b.y,0)) del(bullet,b)
		if prc(b,p2) then sfx(1)del(bullet,b) if p2.hp < 0 then p2.vx+=b.vx elseif p2.pwr~=2 then p2.hp-=1else p2.hp-=.5end
		elseif prc(b,p) then sfx(1)del(bullet,b) if p.hp < 0 then p.vx+=b.vx else p.hp -= 1 end end
		
	end
end

function _update()
	if usecpu then
		cpupdate()
	end
	for d in all(delays) do
		d:update()
	end
	updtmenu()
	if (dofade) fadep += 0.08
	if not mplay and not inmenu then music(1) mplay = true end
	if p.y > lheight*8 and btn(🅾️) or p2.y > lheight*8 and btn(🅾️) then reload() _init() dofade = true end
	if p.y > lheight*8 and btn(🅾️,1) or p2.y > lheight*8 and btn(🅾️,1) then reload() _init() dofade = true end
	
	fxupdate()
	if time()/5 == time()\5 then newitem(rnd(127),10,rnd({56,57,58,59})) end 
--	if time()/5 == time()\5 then newitem(rnd(127),10,rnd({58})) end 
	updateitem()
	
	--[[ ]
	for i=0,3 do
		poke(rnd(0x8000),rnd(0x100))
	end--]]--
	bullet_update()
	if wtick > 10 then
		for x=0,127 do for y=0,63 do
			if mget(x,y) == 20 then mset(x,y,21)
			elseif mget(x,y) == 21 then mset(x,y,20) end
			if mget(x,y) == 36 then mset(x,y,37)
			elseif mget(x,y) == 37 then mset(x,y,36) end
		end end
		wtick = 0
	else wtick += 1
	end
--[[ ]]
	if ltick>50 then ltick = 0for x=0,15 do
		mset(x,lheight,20)
		mset(x,lheight+1,22)
	end lheight -= 1
	else ltick +=1 end
	--]]--
	if p.f < 3 then p.f += abs(p.vx/2) else p.f = 0 end
	if p2.f < 3 then p2.f += abs(p2.vx/2) else p2.f = 0 end
	
	if btn(❎) and p.lac > -1 and not inmenu and p.pwr~=2then
		if p.flipx then
			p.vx += 0.2 shoot(p.x,p.y+2,-3,0,12) p.lac-=1.5 
		else
			p.vx -= 0.2 shoot(p.x+10,p.y+2,3,0,12) p.lac-=1.5 
		end
	else
		p.lac += 0.5 end
	if btn(❎,1) and p2.lac > -1 and not inmenu and p2.pwr~=2then
		if p2.flipx then
			p2.vx += 0.2 shoot(p2.x,p2.y+2,-3,0,8) p2.lac-=1.5 
		else
			p2.vx -= 0.2 shoot(p2.x+10,p2.y+2,3,0,8) p2.lac-=1.5 
		end
	else
		p2.lac += 0.5 end
	if btn(➡️) and not inmenu then p.flipx = false p.vx += 0.1
	elseif btn(⬅️) and not inmenu then p.flipx = true p.vx -= 0.1
	else p.vx = p.vx / 1.6 end
	
	if btn(➡️,1) and not inmenu then p2.flipx = false p2.vx += 0.1
	elseif btn(⬅️,1) and not inmenu then p2.flipx = true p2.vx -= 0.1
	else p2.vx = p2.vx / 1.6 end
	
	if tcol(p2.x,p2.y) and p2.vy < 0 then p2.vy = 0 end
	if tcol(p2.x,p2.y+4) and p2.vx < 0 then p2.vx = 0 end
	if tcol(p2.x+8,p2.y+4) and p2.vx > 0 then p2.vx = 0 end
	if tcol(p2.x+4,p2.y+8,0) and p2.vy > 0 then p2.vy = 0 else p.vy +=0.1 end
	if tcol(p2.x+4,p2.y+8,0) then p2.vy = 0 else p2.vy +=0.2 end
	if btn(🅾️,1) and not inmenu and tcol(p2.x+4,p2.y+8,0) or btn(⬆️,1) and not inmenu and tcol(p2.x+4,p2.y+8,0) then sfx(3)p2.vy = -3.5 end
	
	if p.lac > 50 then p.lac = 50 end
	if p2.lac > 50 then p2.lac = 50 end
	
	if tcol(p.x,p.y) and p.vy < 0 then p.vy = 0 end
	if tcol(p.x,p.y+4) and p.vx < 0 then p.vx = 0 end
	if tcol(p.x+8,p.y+4) and p.vx > 0 then p.vx = 0 end
	if tcol(p.x+4,p.y+8,0) and p.vy > 0 then p.vy = 0 else p.vy +=0.1 end
	if tcol(p.x+4,p.y+8,0) then p.vy = 0 else p.vy +=0.01 end
	if btn(🅾️) and not inmenu and tcol(p.x+4,p.y+8,0) or btn(⬆️) and not inmenu and tcol(p.x+4,p.y+8,0) then  sfx(3)p.vy = -3.5 end
	
	p.vx = mid(-2,p.vx,2)
	p2.vx = mid(-2,p2.vx,2)
	
	p.x += p.vx*tspd
	p.y += p.vy*tspd
	p2.x += p2.vx*tspd
	p2.y += p2.vy*tspd
	
	if p.pwr == 1 then
		p.pwrt -= 1 p.lac = 70
		if (p.pwrt < 0) p.pwr=0
	elseif p.pwr == 2 then
		p.pwrt -= 1 p.vx=0 p.vy=max(0,p.vy)
		if (p.pwrt < 0) p.pwr=0
	end
	if p2.pwr == 1 then
		p2.pwrt -= 1 p2.lac = 70
		if (p2.pwrt < 0) p2.pwr=0
	elseif p2.pwr == 2 then
		p2.pwrt -= 1 p2.vx=0 p2.vy=max(0,p2.vy)
		if (p2.pwrt < 0) p2.pwr=0
	end
	
	if p.hp > 30 then p.hp = 30 end
	if p2.hp > 30 then p2.hp = 30 end
	--printh(abs(p2.vx),"player2debug.txt")
	--printh(abs(p.vx),"player1debug.txt")
end

function _draw()
	local altc = function(col)if col==12 then return 15 else return 13 end end
	local flashtab={7,11}
	cls()
	draw_big(bg)
	for b in all(bullet) do
		circ(b.x,b.y,3,altc(b.c))
	end
	for b in all(bullet) do
		circfill(b.x,b.y,2,b.c)
	end
	for i in all(item) do
		spr(i.t,i.x-4,i.y-4)
	end
	for fx in all(particle) do
		circfill(fx.x,fx.y,fx.s,fx.c)
	end
--	spr(1+p.f,p.x,p.y,1,1,p.flipx)
	sspr(8+flr(p.f)*8,0,8,8,p.x,p.y,8+abs(p.vx*2)-abs(p.vy),8+abs(p.vy*2)-abs(p.vx),p.flipx)
--	spr(5+p2.f,p2.x,p2.y,1,1,p2.flipx)
	sspr(8+flr(p2.f+4)*8,0,8,8,p2.x,p2.y,8+abs(p2.vx*2)-abs(p2.vy),8+abs(p2.vy*2)-abs(p2.vx),p2.flipx)
	if(p.pwr==2)spr(15-p.pwrt\46.6667,p.x,p.y+1)
	if(p2.pwr==2)spr(15-p2.pwrt\46.6667,p2.x,p2.y+1)
	map()
	rrect(73,0,41,11,3,13)
	rrect(15,0,41,11,3,15)
	for s=0,p.hp do
		circfill(20+s,5,4,12)
	end
	for s=0,p2.hp do
		circfill(108-s,5,4,8)
	end
	line(108,15,108-p2.lac/2,15,8)
	line(20,15,20+p.lac/2,15,12)
	if (p.pwr==1) line(20,15,20+p.lac/2,15,rnd({7,11}))
	if (p2.pwr==1) line(108,15,108-p2.lac/2,15,rnd({7,11}))
	if p.hp > -1 then circfill(20,4,1,7) circfill(21,4,1,7) end
	if p2.hp > -1 then circfill(109-p2.hp,4,1,7) circfill(108-p2.hp,4,1,7) end
	spr(5,118,2,1,1,true)
	spr(2,4,2)
	if ltick > 0 then spr(55,60,4) end
	if p.y > lheight*8 or p2.y > lheight*8 then music(-1)  print("\^o1ff🅾️ to restart",40,15,7) sspr(8*8,8,28,16,110*easeoutinquart(kotime),50,28*2,16*2) if kotime < 1 then kotime += 0.05 end end
	if kotime > 0 and kotime < 0.1 then sfx(4) end
	if debug.velo_lines then line(p.x+3.5,p.y+3.5,p.x+3.5+p.vx*5,p.y+3.5+p.vy*5,8) line(p2.x+3.5,p2.y+3.5,p2.x+3.5+p2.vx*5,p2.y+3.5+p2.vy*5,8) end
	if(debug.cpudata)line(p.x+18,-100,p.x+18,200,8) line(p.x-10,-100,p.x-10,200,8) line(-100,p.y+3,200,p.y+3,8)
	drawmenu()
	if (dofade and fadep<1) fade(1-fadep)
	if (dofade and fadep>1) fade(fadep-1)
end

-->8
--background

function sti(s)
    local draw_arr = {}
    for i=1,#s,6 do
        local a = {}
        for k=1,6 do
            add(a, ord(sub(s,i,i+5),k))
        end
        add(draw_arr, a)
    end
    return draw_arr
end

